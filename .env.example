PORT=3000
JWT_SECRET=change-me-in-production

# Opção A — URL única (Fly.io / Docker Compose / provedores gerenciados)
# DATABASE_URL=postgres://user:pass@host:5432/roadmap

# Opção B — variáveis separadas (Postgres local sem URL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=roadmap

# Produção: alguns hosts exigem SSL ao usar DATABASE_URL
# DATABASE_SSL=true

# Só em produção na Fly: true UMA VEZ para criar tabelas, depois remover/unset
# TYPEORM_SYNCHRONIZE=true
